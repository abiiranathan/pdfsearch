{
  "clangd.path": "/usr/bin/clangd",
  "clangd.fallbackFlags": [
    "-I${workspaceFolder}/**",
    "-I/usr/include/glib-2.0",
    "-I/usr/lib/x86_64-linux-gnu/glib-2.0/include",
    "-I/usr/include/cairo/",
    "-I/usr/include/poppler/**"
  ],
  "clangd.checkUpdates": false,
  "clangd.serverCompletionRanking": true
}
